<div class="space-y-6">
  <div
    class="bg-white rounded-3xl border border-slate-200 shadow-[0_24px_80px_-36px_rgba(15,23,42,0.14)] p-8"
  >
    <div class="mb-6">
      <a
        href="/folders"
        class="inline-flex items-center gap-2 text-slate-600 hover:text-slate-900 transition duration-200"
      >
        <i class="fa-solid fa-arrow-left text-lg"></i>
      </a>
    </div>

    <div
      class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between"
    >
      <div class="flex items-start gap-4">
        <div
          class="h-16 w-16 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center"
        >
          <i class="fa-solid fa-folder text-3xl"></i>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-slate-900"><%= folder.name %></h1>
          <p class="text-slate-600">
            Created on <%= folder.createdAt.toLocaleDateString('en-US', { year:
            'numeric', month: 'long', day: 'numeric' }) %>
          </p>
        </div>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          href="/folders/<%= folder.id %>/edit"
          class="inline-flex items-center gap-2 bg-blue-600 text-white px-5 py-3 rounded-2xl shadow-[0_15px_40px_-25px_rgba(37,99,235,0.35)] hover:bg-blue-500 transition duration-200"
        >
          <i class="fa-solid fa-edit"></i>Edit
        </a>
        <form
          action="/folders/<%= folder.id %>/delete"
          method="POST"
          onsubmit="
            return confirm(
              'Are you sure you want to delete this folder and all its files?',
            );
          "
          class="inline"
        >
          <button
            type="submit"
            class="inline-flex items-center gap-2 bg-red-600 text-white px-5 py-3 rounded-2xl shadow-[0_15px_40px_-25px_rgba(220,38,38,0.35)] hover:bg-red-500 transition duration-200"
          >
            <i class="fa-solid fa-trash"></i>Delete
          </button>
        </form>
      </div>
    </div>
  </div>

  <div
    class="bg-white rounded-2xl border border-slate-200 shadow-[0_22px_80px_-38px_rgba(15,23,42,0.12)] overflow-hidden"
  >
    <div
      class="px-6 py-4 border-b border-slate-200 flex flex-col gap-4 md:flex-row md:items-center md:justify-between"
    >
      <h2 class="text-lg font-semibold text-slate-900">
        Files in this folder (<%= folder.files.length %>)
      </h2>
      <a
        href="/files/upload?folderId=<%= folder.id %>"
        class="inline-flex items-center gap-2 bg-blue-600 text-white px-4 py-3 rounded-2xl shadow-[0_15px_40px_-25px_rgba(37,99,235,0.35)] hover:bg-blue-500 transition duration-200"
      >
        <i class="fa-solid fa-upload"></i>Upload File
      </a>
    </div>

    <% if (folder.files.length === 0) { %>
    <div class="bg-slate-50 p-12 text-center">
      <i class="fa-solid fa-file text-4xl text-slate-300 mb-4"></i>
      <h3 class="text-lg font-semibold text-slate-900 mb-2">
        No files in this folder
      </h3>
      <p class="text-slate-600 mb-6">Upload your first file to get started</p>
      <a
        href="/files/upload?folderId=<%= folder.id %>"
        class="inline-flex items-center gap-2 bg-blue-600 text-white px-6 py-3 rounded-2xl shadow-[0_15px_40px_-25px_rgba(37,99,235,0.35)] hover:bg-blue-500 transition duration-200"
      >
        <i class="fa-solid fa-upload"></i>Upload File
      </a>
    </div>
    <% } else { %>
    <div class="space-y-4 p-6">
      <% folder.files.forEach(file => { %>
      <div
        class="bg-slate-50 rounded-2xl border border-slate-200 p-5 hover:shadow-sm transition duration-200"
      >
        <div
          class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between"
        >
          <div class="flex items-center gap-4">
            <div
              class="h-12 w-12 rounded-3xl bg-blue-50 text-blue-600 flex items-center justify-center"
            >
              <i class="fa-solid fa-file text-xl"></i>
            </div>
            <div>
              <a
                href="/files/<%= file.id %>?returnTo=/folders/<%= folder.id %>"
                class="text-lg font-semibold text-slate-900 hover:text-blue-600 transition duration-200"
              >
                <%= file.name %>
              </a>
              <p class="text-sm text-slate-500 mt-1">
                Uploaded on <%= file.uploadedAt.toLocaleDateString('en-US', {
                year: 'numeric', month: 'long', day: 'numeric' }) %><% if
                (file.size) { %> • <%= (file.size / 1024 / 1024).toFixed(2) %>
                MB<% } %>
              </p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <a
              href="/files/<%= file.id %>/download"
              class="inline-flex items-center justify-center h-11 w-11 rounded-2xl bg-white text-blue-600 border border-slate-200 hover:bg-blue-50 transition duration-200"
            >
              <i class="fa-solid fa-download"></i>
            </a>
            <a
              href="/files/<%= file.id %>?returnTo=/folders/<%= folder.id %>"
              class="inline-flex items-center justify-center h-11 w-11 rounded-2xl bg-white text-slate-600 border border-slate-200 hover:bg-slate-100 transition duration-200"
            >
              <i class="fa-solid fa-eye"></i>
            </a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>
