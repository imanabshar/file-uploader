<div class="space-y-6">
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8">
    <div class="mb-6">
      <a href="/folders">
        <i class="fa-solid fa-arrow-left mr-2 text-lg"></i>
      </a>
    </div>

    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center space-x-4">
        <i class="fa-solid fa-folder text-4xl text-indigo-500"></i>
        <div>
          <h1 class="text-3xl font-bold text-gray-800"><%= folder.name %></h1>
          <p class="text-gray-600">
            Created on <%= folder.createdAt.toDateString() %>
          </p>
        </div>
      </div>
      <div class="flex space-x-2">
        <a
          href="/folders/<%= folder.id %>/edit"
          class="bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 transition duration-200"
        >
          <i class="fa-solid fa-edit"></i>
        </a>
        <form
          action="/folders/<%= folder.id %>/delete"
          method="POST"
          onsubmit="
            return confirm(
              'Are you sure you want to delete this folder and all its files?',
            );
          "
          class="inline"
        >
          <button
            type="submit"
            class="bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 transition duration-200"
          >
            <i class="fa-solid fa-trash"></i>
          </button>
        </form>
      </div>
    </div>
  </div>

  <div
    class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden"
  >
    <div
      class="px-6 py-4 border-b border-gray-200 flex items-center justify-between"
    >
      <h2 class="text-lg font-semibold text-gray-800">
        Files in this folder (<%= folder.files.length %>)
      </h2>
      <a
        href="/files/upload?folderId=<%= folder.id %>"
        class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition duration-200"
      >
        <i class="fa-solid fa-upload mr-2"></i>Upload File
      </a>
    </div>

    <% if (folder.files.length === 0) { %>
    <div class="text-center py-12">
      <i class="fa-solid fa-file text-4xl text-gray-300 mb-4"></i>
      <h3 class="text-lg font-medium text-gray-800 mb-2">
        No files in this folder
      </h3>
      <p class="text-gray-600 mb-6">Upload your first file to get started</p>
      <a
        href="/files/upload?folderId=<%= folder.id %>"
        class="bg-indigo-600 text-white px-6 py-3 rounded-lg hover:bg-indigo-700 transition duration-200"
      >
        <i class="fa-solid fa-upload mr-2"></i>Upload File
      </a>
    </div>
    <% } else { %>
    <div class="divide-y divide-gray-200">
      <% folder.files.forEach(file => { %>
      <div class="px-6 py-4 hover:bg-gray-50 transition duration-200">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <div class="flex-shrink-0">
              <i class="fa-solid fa-file text-2xl text-indigo-500"></i>
            </div>
            <div>
              <a
                href="/files/<%= file.id %>"
                class="text-lg font-medium text-gray-800 hover:text-indigo-600 transition duration-200"
              >
                <%= file.name %>
              </a>
              <p class="text-sm text-gray-600">
                Uploaded on <%= file.uploadedAt.toDateString() %> <% if
                (file.size) { %> • <%= (file.size / 1024 / 1024).toFixed(2) %>
                MB <% } %>
              </p>
            </div>
          </div>
          <div class="flex items-center space-x-2">
            <a
              href="/files/<%= file.id %>/download"
              class="text-indigo-600 hover:text-indigo-700 p-2 rounded-lg hover:bg-indigo-50 transition duration-200"
            >
              <i class="fa-solid fa-download"></i>
            </a>
            <a
              href="/files/<%= file.id %>"
              class="text-gray-600 hover:text-indigo-600 p-2 rounded-lg hover:bg-gray-50 transition duration-200"
            >
              <i class="fa-solid fa-eye"></i>
            </a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>
