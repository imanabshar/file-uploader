<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-800">My Folders</h1>
      <p class="text-gray-600 mt-1">Organize your files into folders</p>
    </div>
    <a
      href="/folders/new"
      class="bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 transition duration-200"
    >
      <i class="fa-solid fa-folder-plus mr-2"></i>Create Folder
    </a>
  </div>

  <% if (folders.length === 0) { %>
  <div class="text-center py-12">
    <i class="fa-solid fa-folder text-6xl text-gray-300 mb-4"></i>
    <h3 class="text-lg font-medium text-gray-800 mb-2">No folders yet</h3>
    <p class="text-gray-600 mb-6">Create your first folder to get organized</p>
    <a
      href="/folders/new"
      class="bg-indigo-600 text-white px-6 py-3 rounded-lg hover:bg-indigo-700 transition duration-200"
    >
      Create Your First Folder
    </a>
  </div>
  <% } else { %>
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% folders.forEach(folder => { %>
    <div
      class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:shadow-md transition duration-200"
    >
      <div class="flex items-start justify-between mb-4">
        <div class="flex items-center space-x-3">
          <i class="fa-solid fa-folder text-3xl text-indigo-500"></i>
          <div>
            <a
              href="/folders/<%= folder.id %>"
              class="text-lg font-semibold text-gray-800 hover:text-indigo-600 transition duration-200"
            >
              <%= folder.name %>
            </a>
            <p class="text-sm text-gray-600">
              Created: <%= folder.createdAt.toLocaleDateString('en-US', { year:
              'numeric', month: 'long', day: 'numeric' }) %>
            </p>
          </div>
        </div>
      </div>

      <div class="flex items-center justify-between">
        <div class="text-sm text-gray-600">
          <%= folder._count ? folder._count.files : 0 %> file<%= (folder._count
          && folder._count.files !== 1) ? 's' : '' %>
        </div>
        <div class="flex space-x-2">
          <a
            href="/folders/<%= folder.id %>/edit"
            class="text-gray-600 hover:text-indigo-600 p-2 rounded-lg hover:bg-gray-50 transition duration-200"
          >
            <i class="fa-solid fa-edit"></i>
          </a>
          <form
            action="/folders/<%= folder.id %>/delete"
            method="POST"
            onsubmit="
              return confirm('Are you sure you want to delete this folder?');
            "
            class="inline"
          >
            <button
              type="submit"
              class="text-gray-600 hover:text-red-600 p-2 rounded-lg hover:bg-red-50 transition duration-200"
            >
              <i class="fa-solid fa-trash"></i>
            </button>
          </form>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>
