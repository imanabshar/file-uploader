<div class="space-y-6">
  <div
    class="bg-white rounded-3xl border border-slate-200 shadow-[0_24px_80px_-36px_rgba(15,23,42,0.14)] p-8"
  >
    <div
      class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between"
    >
      <div>
        <h1 class="text-3xl font-bold text-slate-900">My Folders</h1>
        <p class="text-slate-600 mt-1">Organize your files into folders</p>
      </div>
      <a
        href="/folders/new"
        class="inline-flex items-center gap-2 bg-blue-600 text-white px-5 py-3 rounded-2xl shadow-[0_15px_40px_-25px_rgba(37,99,235,0.35)] hover:bg-blue-500 transition duration-200"
      >
        <i class="fa-solid fa-folder-plus"></i>Create Folder
      </a>
    </div>
  </div>

  <% if (folders.length === 0) { %>
  <div
    class="bg-white rounded-2xl border border-slate-200 shadow-[0_24px_80px_-36px_rgba(15,23,42,0.10)] p-12 text-center"
  >
    <i class="fa-solid fa-folder text-6xl text-slate-300 mb-4"></i>
    <h3 class="text-lg font-medium text-slate-900 mb-2">No folders yet</h3>
    <p class="text-slate-600 mb-6">Create your first folder to get organized</p>
    <a
      href="/folders/new"
      class="inline-flex items-center gap-2 bg-blue-600 text-white px-6 py-3 rounded-2xl shadow-[0_15px_40px_-25px_rgba(37,99,235,0.35)] hover:bg-blue-500 transition duration-200"
    >
      Create Your First Folder
    </a>
  </div>
  <% } else { %>
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% folders.forEach(folder => { %>
    <div
      class="bg-white rounded-3xl border border-slate-200 p-6 shadow-sm hover:shadow-md transition duration-200"
    >
      <div class="flex items-start justify-between mb-4 gap-4">
        <div class="flex items-center gap-3">
          <div
            class="h-14 w-14 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center"
          >
            <i class="fa-solid fa-folder text-2xl"></i>
          </div>
          <div>
            <a
              href="/folders/<%= folder.id %>"
              class="text-lg font-semibold text-slate-900 hover:text-blue-600 transition duration-200"
            >
              <%= folder.name %>
            </a>
            <p class="text-sm text-slate-500 mt-1">
              Created: <%= folder.createdAt.toLocaleDateString('en-US', { year:
              'numeric', month: 'long', day: 'numeric' }) %>
            </p>
          </div>
        </div>
      </div>

      <div class="flex items-center justify-between">
        <div class="text-sm text-slate-600">
          <%= folder._count ? folder._count.files : 0 %> file<%= (folder._count
          && folder._count.files !== 1) ? 's' : '' %>
        </div>
        <div class="flex items-center gap-2">
          <a
            href="/folders/<%= folder.id %>/edit"
            class="inline-flex items-center justify-center h-10 w-10 rounded-2xl bg-slate-100 text-slate-600 hover:text-blue-600 hover:bg-slate-200 transition duration-200"
          >
            <i class="fa-solid fa-edit"></i>
          </a>
          <form
            action="/folders/<%= folder.id %>/delete"
            method="POST"
            onsubmit="
              return confirm('Are you sure you want to delete this folder?');
            "
            class="inline"
          >
            <button
              type="submit"
              class="inline-flex items-center justify-center h-10 w-10 rounded-2xl bg-slate-100 text-slate-600 hover:text-red-600 hover:bg-red-50 transition duration-200"
            >
              <i class="fa-solid fa-trash"></i>
            </button>
          </form>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>
