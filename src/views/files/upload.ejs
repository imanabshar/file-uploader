<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Upload File</title>
  </head>
  <body>
    <h1>Upload File</h1>
    <% if (locals.error) { %>
    <p><%= error %></p>
    <% } %>

    <form
      action="/files/upload?folderId=<%= locals.folderId || '' %>"
      method="POST"
      enctype="multipart/form-data"
    >
      <input type="file" name="file" />
      <button type="submit">Upload</button>
    </form>
  </body>
</html>
