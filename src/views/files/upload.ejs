<div class="max-w-2xl mx-auto">
  <div
    class="bg-white rounded-[2rem] border border-slate-200 shadow-[0_24px_80px_-36px_rgba(15,23,42,0.14)] p-8 relative"
  >
    <a
      href="<%= returnTo || (locals.folderId ? `/folders/${locals.folderId}` : '/files') %>"
      class="absolute right-6 top-6 inline-flex items-center justify-center h-11 w-11 rounded-full bg-slate-100 text-slate-600 hover:text-slate-900 hover:bg-slate-200 transition duration-200"
      aria-label="Cancel upload"
    >
      <i class="fa-solid fa-times"></i>
    </a>

    <div class="text-center mb-8">
      <i class="fa-solid fa-cloud-upload-alt text-6xl text-blue-600 mb-4"></i>
      <h1 class="text-3xl font-bold text-slate-900">Upload File</h1>
      <p class="text-slate-600">Select a file to upload to your storage</p>
    </div>

    <% if (locals.error) { %>
    <div class="mb-6 bg-red-50 border border-red-200 rounded-[1.5rem] p-4">
      <p class="text-red-700"><%= error %></p>
    </div>
    <% } %>

    <form
      action="/files/upload?folderId=<%= locals.folderId || '' %>"
      method="POST"
      enctype="multipart/form-data"
      class="space-y-6"
    >
      <input type="hidden" name="returnTo" value="<%= returnTo || '' %>" />
      <div
        class="bg-slate-50 rounded-[1.75rem] border border-slate-200 p-8 text-center shadow-sm hover:shadow-md transition duration-200"
      >
        <div class="space-y-4">
          <i class="fa-solid fa-file-upload text-4xl text-gray-300"></i>
          <div>
            <p class="text-lg text-slate-700 mb-2">
              Click to browse and upload your file
            </p>
            <p class="text-sm text-slate-500">
              Supported formats: JPG, JPEG, PNG, PDF, DOC, DOCX (max 8MB)
            </p>
          </div>
          <input
            type="file"
            name="file"
            id="file"
            class="hidden"
            onchange="updateFileName()"
          />
          <label
            for="file"
            class="inline-flex items-center justify-center gap-2 bg-blue-600 text-white px-6 py-3 rounded-2xl hover:bg-blue-500 transition duration-200 cursor-pointer"
          >
            <i class="fa-solid fa-folder-open"></i>Choose File
          </label>
          <p id="file-name" class="text-sm text-slate-500 mt-2"></p>
        </div>
      </div>

      <button
        type="submit"
        class="w-full bg-blue-600 text-white py-3 px-4 rounded-2xl hover:bg-blue-500 transition duration-200 font-medium"
      >
        Upload File
      </button>
    </form>
  </div>
</div>

<script>
  function updateFileName() {
    const fileInput = document.getElementById('file');
    const fileNameDisplay = document.getElementById('file-name');
    if (fileInput.files.length > 0) {
      fileNameDisplay.textContent = `Selected: ${fileInput.files[0].name}`;
    } else {
      fileNameDisplay.textContent = '';
    }
  }
</script>
