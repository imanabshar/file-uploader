<div class="space-y-6">
  <div
    class="bg-white rounded-3xl border border-slate-200 shadow-[0_24px_80px_-36px_rgba(15,23,42,0.14)] p-8"
  >
    <div
      class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between"
    >
      <div>
        <h1 class="text-3xl font-bold text-slate-900">My Files</h1>
        <p class="text-slate-600 mt-1">Manage and view your uploaded files</p>
      </div>
      <a
        href="/files/upload?returnTo=/files"
        class="inline-flex items-center gap-2 bg-blue-600 text-white px-5 py-3 rounded-2xl shadow-[0_15px_40px_-25px_rgba(37,99,235,0.35)] hover:bg-blue-500 transition duration-200"
      >
        <i class="fa-solid fa-upload"></i>Upload File
      </a>
    </div>
  </div>

  <% if (files.length === 0) { %>
  <div
    class="bg-white rounded-2xl border border-slate-200 shadow-[0_24px_80px_-36px_rgba(15,23,42,0.10)] p-12 text-center"
  >
    <i class="fa-solid fa-file text-6xl text-slate-300 mb-4"></i>
    <h3 class="text-lg font-medium text-slate-900 mb-2">No files yet</h3>
    <p class="text-slate-600 mb-6">Start by uploading your first file</p>
    <a
      href="/files/upload?returnTo=/files"
      class="inline-flex items-center gap-2 bg-blue-600 text-white px-6 py-3 rounded-2xl shadow-[0_15px_40px_-25px_rgba(37,99,235,0.35)] hover:bg-blue-500 transition duration-200"
    >
      Upload Your First File
    </a>
  </div>
  <% } else { %>
  <div class="space-y-4">
    <% files.forEach(file => { %>
    <div
      class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 hover:shadow-md transition duration-200"
    >
      <div
        class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between"
      >
        <div class="flex items-center gap-4">
          <div
            class="h-12 w-12 rounded-3xl bg-blue-50 text-blue-600 flex items-center justify-center"
          >
            <i class="fa-solid fa-file text-xl"></i>
          </div>
          <div>
            <a
              href="/files/<%= file.id %>?returnTo=/files"
              class="text-lg font-semibold text-slate-900 hover:text-blue-600 transition duration-200"
            >
              <%= file.name %>
            </a>
            <p class="text-sm text-slate-500 mt-1">
              Uploaded on <%= file.uploadedAt.toLocaleDateString('en-US', {
              year: 'numeric', month: 'long', day: 'numeric' }) %><% if
              (file.size) { %> • <%= (file.size / 1024 / 1024).toFixed(2) %>
              MB<% } %>
            </p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <a
            href="/files/<%= file.id %>?returnTo=/files"
            class="inline-flex items-center justify-center rounded-2xl bg-blue-50 text-blue-600 p-3 hover:bg-blue-100 transition duration-200"
          >
            <i class="fa-solid fa-eye"></i>
          </a>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>
