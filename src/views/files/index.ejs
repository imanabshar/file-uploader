<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-800">My Files</h1>
      <p class="text-gray-600 mt-1">Manage and view your uploaded files</p>
    </div>
    <a
      href="/files/upload"
      class="bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 transition duration-200"
    >
      <i class="fa-solid fa-upload mr-2"></i>Upload File
    </a>
  </div>

  <% if (files.length === 0) { %>
  <div class="text-center py-12">
    <i class="fa-solid fa-file text-6xl text-gray-300 mb-4"></i>
    <h3 class="text-lg font-medium text-gray-800 mb-2">No files yet</h3>
    <p class="text-gray-600 mb-6">Start by uploading your first file</p>
    <a
      href="/files/upload"
      class="bg-indigo-600 text-white px-6 py-3 rounded-lg hover:bg-indigo-700 transition duration-200"
    >
      Upload Your First File
    </a>
  </div>
  <% } else { %>
  <div
    class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden"
  >
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-800">
        <%= files.length %> File<%= files.length !== 1 ? 's' : '' %>
      </h2>
    </div>
    <div class="divide-y divide-gray-200">
      <% files.forEach(file => { %>
      <div class="px-6 py-4 hover:bg-gray-50 transition duration-200">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <div class="flex-shrink-0">
              <i class="fa-solid fa-file text-2xl text-indigo-500"></i>
            </div>
            <div>
              <a
                href="/files/<%= file.id %>"
                class="text-lg font-medium text-gray-800 hover:text-indigo-600 transition duration-200"
              >
                <%= file.name %>
              </a>
              <p class="text-sm text-gray-600">
                Uploaded on <%= file.uploadedAt.toDateString() %> <% if
                (file.size) { %> • <%= (file.size / 1024 / 1024).toFixed(2) %>
                MB <% } %>
              </p>
            </div>
          </div>
          <div class="flex items-center space-x-2">
            <a
              href="/files/<%= file.id %>"
              class="text-indigo-600 hover:text-indigo-700 p-2 rounded-lg hover:bg-indigo-50 transition duration-200"
            >
              <i class="fa-solid fa-eye"></i>
            </a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <% } %>
</div>
