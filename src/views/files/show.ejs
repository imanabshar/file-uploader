<div class="max-w-3xl mx-auto space-y-6">
  <div
    class="bg-white rounded-[2rem] border border-slate-200 shadow-[0_24px_80px_-36px_rgba(15,23,42,0.14)] p-8"
  >
    <div class="mb-6">
      <a
        href="<%= returnTo || '/files' %>"
        class="inline-flex items-center gap-2 text-slate-600 hover:text-slate-900 transition duration-200"
      >
        <i class="fa-solid fa-arrow-left text-lg"></i>Back to files
      </a>
    </div>

    <div class="text-center mb-8">
      <i class="fa-solid fa-file text-6xl text-blue-600 mb-4"></i>
      <h1 class="text-3xl font-bold text-slate-900"><%= file.name %></h1>
    </div>

    <div class="mb-8">
      <div
        class="bg-slate-50 rounded-[1.75rem] border border-slate-200 p-6 max-w-md mx-auto shadow-sm"
      >
        <h3
          class="text-sm font-semibold text-slate-500 uppercase tracking-[0.2em] mb-4"
        >
          File Details
        </h3>
        <div class="space-y-3 text-slate-700">
          <div class="flex justify-between">
            <span>Size:</span>
            <span class="font-medium"
              ><%= (file.size / 1024 / 1024).toFixed(2) %>
              MB</span
            >
          </div>
          <div class="flex justify-between">
            <span>Uploaded:</span>
            <span class="font-medium"
              ><%= file.uploadedAt.toLocaleDateString('en-US', { year:
              'numeric', month: 'long', day: 'numeric' }) %></span
            >
          </div>
          <% if (file.folder) { %>
          <div class="flex justify-between">
            <span>Folder:</span>
            <a
              href="/folders/<%= file.folder.id %>"
              class="font-medium text-blue-600 hover:text-blue-500"
            >
              <%= file.folder.name %>
            </a>
          </div>
          <% } %>
        </div>
      </div>

      <div class="mt-6 text-center">
        <a
          href="/files/<%= file.id %>/download"
          class="inline-flex items-center justify-center gap-2 bg-blue-600 text-white py-3 px-5 rounded-2xl shadow-[0_15px_40px_-25px_rgba(37,99,235,0.35)] hover:bg-blue-500 transition duration-200"
        >
          <i class="fa-solid fa-download"></i>Download File
        </a>
      </div>
    </div>

    <% if (file.url && (file.url.includes('.jpg') || file.url.includes('.jpeg') || file.url.includes('.png') || file.url.includes('.gif'))) { %>
    <div class="text-center">
      <h3 class="text-lg font-semibold text-slate-900 mb-4">Preview</h3>
      <img
        src="<%= file.url %>"
        alt="<%= file.name %>"
        class="max-w-full h-auto rounded-[1.75rem] shadow-[0_20px_60px_-40px_rgba(15,23,42,0.15)] border border-slate-200 mx-auto"
      />
    </div>
    <% } %>
  </div>
</div>
