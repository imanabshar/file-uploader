<div class="max-w-2xl mx-auto space-y-6">
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8">
    <div class="mb-6">
      <a href="<%= returnTo || '/files' %>">
        <i class="fa-solid fa-arrow-left mr-2 text-lg"></i>
      </a>
    </div>

    <div class="text-center mb-8">
      <i class="fa-solid fa-file text-6xl text-indigo-500 mb-4"></i>
      <h1 class="text-3xl font-bold text-gray-800"><%= file.name %></h1>
    </div>

    <div class="mb-8">
      <div class="bg-gray-50 rounded-lg p-4 max-w-md mx-auto">
        <h3
          class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-2"
        >
          File Details
        </h3>
        <div class="space-y-2">
          <div class="flex justify-between">
            <span class="text-gray-600">Size:</span>
            <span class="font-medium"
              ><%= (file.size / 1024 / 1024).toFixed(2) %>
              MB</span
            >
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Uploaded:</span>
            <span class="font-medium"
              ><%= file.uploadedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span
            >
          </div>
          <% if (file.folder) { %>
          <div class="flex justify-between">
            <span class="text-gray-600">Folder:</span>
            <a
              href="/folders/<%= file.folder.id %>"
              class="font-medium text-indigo-600 hover:text-indigo-700"
            >
              <%= file.folder.name %>
            </a>
          </div>
          <% } %>
        </div>
      </div>

      <div class="mt-4 text-center">
        <a
          href="/files/<%= file.id %>/download"
          class="inline-block bg-indigo-600 text-white py-2 px-4 rounded-lg hover:bg-indigo-700 transition duration-200"
        >
          <i class="fa-solid fa-download mr-2"></i>Download File
        </a>
      </div>
    </div>

    <% if (file.url && (file.url.includes('.jpg') || file.url.includes('.jpeg') || file.url.includes('.png') || file.url.includes('.gif'))) { %>
    <div class="text-center">
      <h3 class="text-lg font-semibold text-gray-800 mb-4">Preview</h3>
      <img
        src="<%= file.url %>"
        alt="<%= file.name %>"
        class="max-w-full h-auto rounded-lg shadow-sm border border-gray-200 mx-auto"
      />
    </div>
    <% } %>
  </div>
</div>
