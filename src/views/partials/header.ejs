<header class="bg-white/95 border-b border-slate-200 shadow-sm backdrop-blur">
  <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="text-2xl font-semibold text-slate-900 tracking-tight">
      File Uploader
    </a>

    <nav class="flex items-center gap-4">
      <% if (locals.user) { %>
      <a
        href="/folders"
        class="text-sm text-slate-600 hover:text-slate-900 transition"
      >
        Folders
      </a>
      <a
        href="/files"
        class="text-sm text-slate-600 hover:text-slate-900 transition"
      >
        Files
      </a>
      <a
        href="/files/upload?returnTo=/files"
        class="text-sm text-slate-600 hover:text-slate-900 transition"
      >
        Upload
      </a>
      <form action="/auth/logout" method="POST">
        <button
          type="submit"
          class="text-sm bg-blue-600 text-white px-4 py-1.5 rounded-full hover:bg-blue-500 transition"
        >
          Logout
        </button>
      </form>
      <% } else { %>
      <a
        href="/auth/login"
        class="text-sm text-slate-600 hover:text-slate-900 transition"
        >Login</a
      >
      <a
        href="/auth/signup"
        class="text-sm bg-blue-600 text-white px-4 py-1.5 rounded-full hover:bg-blue-500 transition"
      >
        Sign Up
      </a>
      <% } %>
    </nav>
  </div>
</header>
