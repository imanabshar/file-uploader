<div class="relative overflow-hidden">
  <% if (user) { %>
  <div
    class="relative overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_24px_80px_-34px_rgba(15,23,42,0.18)] p-8 max-w-3xl mx-auto"
  >
    <div
      class="absolute inset-x-0 top-0 h-48 bg-gradient-to-b from-blue-100 to-transparent opacity-70 pointer-events-none"
    ></div>
    <div class="relative text-center">
      <div class="mb-6">
        <i class="fa-solid fa-user-circle text-6xl text-blue-600 mb-4"></i>
        <h1 class="text-3xl sm:text-4xl font-semibold text-slate-900">
          Welcome, <%= user.username %>!
        </h1>
        <p class="text-slate-500 mt-3">Ready to manage your files?</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        <a
          href="/folders"
          class="group block rounded-[1.75rem] border border-slate-200 bg-blue-600 p-5 text-center text-white shadow-[0_15px_40px_-25px_rgba(37,99,235,0.35)] transition hover:bg-blue-500 hover:-translate-y-0.5"
        >
          <div
            class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-3xl bg-white text-blue-600 transition group-hover:bg-slate-100"
          >
            <i class="fa-solid fa-folder"></i>
          </div>
          <span class="text-sm font-semibold">Folders</span>
        </a>
        <a
          href="/files"
          class="group block rounded-[1.75rem] border border-slate-200 bg-slate-50 p-5 text-center shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
        >
          <div
            class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-3xl bg-blue-50 text-blue-600 transition group-hover:bg-blue-100"
          >
            <i class="fa-solid fa-file"></i>
          </div>
          <span class="text-sm font-semibold text-slate-900">Files</span>
        </a>
        <a
          href="/files/upload?returnTo=/"
          class="group block rounded-[1.75rem] border border-slate-200 bg-blue-600 p-5 text-center text-white shadow-[0_15px_40px_-25px_rgba(37,99,235,0.35)] transition hover:bg-blue-500 hover:-translate-y-0.5"
        >
          <div
            class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-3xl bg-white text-blue-600 transition group-hover:bg-slate-100"
          >
            <i class="fa-solid fa-upload"></i>
          </div>
          <span class="text-sm font-semibold">Upload</span>
        </a>
      </div>
    </div>
  </div>
  <% } else { %>
  <section
    class="relative overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_30px_90px_-50px_rgba(15,23,42,0.15)] p-8 sm:p-12"
  >
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(59,130,246,0.18),_transparent_30%),radial-gradient(circle_at_bottom_right,_rgba(37,99,235,0.12),_transparent_25%)] pointer-events-none"
    ></div>
    <div class="relative max-w-3xl mx-auto space-y-5 text-center">
      <div
        class="sm:inline-flex items-center gap-2 rounded-full bg-blue-100 px-4 py-2 text-sm text-blue-700 ring-1 ring-blue-200 hidden"
      >
        <i class="fa-solid fa-star text-blue-600"></i>
        Easy Way to organize your files
      </div>
      <div>
        <h1
          class="text-5xl sm:text-6xl font-extrabold tracking-tight text-slate-900"
        >
          Welcome to File Uploader
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-8 text-slate-600 mx-auto">
          Upload, manage and organize your files
        </p>
      </div>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href="/auth/signup"
          class="inline-flex items-center justify-center rounded-full bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-[0_18px_50px_-30px_rgba(37,99,235,0.35)] hover:bg-blue-500 transition"
        >
          <i class="fa-solid fa-user-plus mr-2"></i>Sign Up
        </a>
        <a
          href="/auth/login"
          class="inline-flex items-center justify-center rounded-full border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50 transition"
        >
          <i class="fa-solid fa-sign-in-alt mr-2"></i>Login
        </a>
      </div>
    </div>
  </section>

  <section class="mt-12 grid gap-6 md:grid-cols-3">
    <div
      class="rounded-[2rem] bg-white border border-slate-200 p-6 shadow-[0_18px_60px_-40px_rgba(15,23,42,0.1)]"
    >
      <div
        class="flex items-center justify-center h-14 w-14 rounded-3xl bg-blue-100 text-blue-600 mb-4 mx-auto"
      >
        <i class="fa-solid fa-upload text-xl"></i>
      </div>
      <h3 class="text-lg font-semibold text-slate-900 text-center mb-2">
        Easy Upload
      </h3>
      <p class="text-sm leading-6 text-slate-600 text-center">
        Upload files easily with just a few clicks
      </p>
    </div>
    <div
      class="rounded-[2rem] bg-white border border-slate-200 p-6 shadow-[0_18px_60px_-40px_rgba(15,23,42,0.1)]"
    >
      <div
        class="flex items-center justify-center h-14 w-14 rounded-3xl bg-sky-100 text-sky-600 mb-4 mx-auto"
      >
        <i class="fa-solid fa-folder text-xl"></i>
      </div>
      <h3 class="text-lg font-semibold text-slate-900 text-center mb-2">
        Organize
      </h3>
      <p class="text-sm leading-6 text-slate-600 text-center">
        Create folders and keep your files organized
      </p>
    </div>
    <div
      class="rounded-[2rem] bg-white border border-slate-200 p-6 shadow-[0_18px_60px_-40px_rgba(15,23,42,0.1)]"
    >
      <div
        class="flex items-center justify-center h-14 w-14 rounded-3xl bg-blue-100 text-blue-600 mb-4 mx-auto"
      >
        <i class="fa-solid fa-shield-alt text-xl"></i>
      </div>
      <h3 class="text-lg font-semibold text-slate-900 text-center mb-2">
        Secure
      </h3>
      <p class="text-sm leading-6 text-slate-600 text-center">
        Your files are stored securely in the cloud
      </p>
    </div>
  </section>
  <% } %>
</div>
