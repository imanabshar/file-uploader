<div class="text-center">
  <% if (user) { %>
  <div
    class="bg-white rounded-lg shadow-sm border border-gray-200 p-8 max-w-md mx-auto"
  >
    <div class="mb-6">
      <i class="fa-solid fa-user-circle text-6xl text-indigo-500 mb-4"></i>
      <h1 class="text-2xl font-semibold text-gray-800">
        Welcome back, <%= user.username %>!
      </h1>
      <p class="text-gray-600 mt-2">Ready to manage your files?</p>
    </div>
    <div class="space-y-3">
      <a
        href="/folders"
        class="block w-full bg-indigo-600 text-white py-2 px-4 rounded-lg hover:bg-indigo-700 transition duration-200"
      >
        <i class="fa-solid fa-folder mr-2"></i>View Folders
      </a>
      <a
        href="/files"
        class="block w-full bg-gray-600 text-white py-2 px-4 rounded-lg hover:bg-gray-700 transition duration-200"
      >
        <i class="fa-solid fa-file mr-2"></i>View Files
      </a>
      <a
        href="/files/upload"
        class="block w-full bg-green-600 text-white py-2 px-4 rounded-lg hover:bg-green-700 transition duration-200"
      >
        <i class="fa-solid fa-upload mr-2"></i>Upload File
      </a>
    </div>
  </div>
  <% } else { %>
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <i class="fa-solid fa-cloud-arrow-up text-8xl text-indigo-500 mb-6"></i>
      <h1 class="text-4xl font-bold text-gray-800 mb-4">
        Welcome to File Uploader
      </h1>
      <p class="text-xl text-gray-600 mb-8">
        Upload, manage and organize your files
      </p>
      <div class="flex justify-center gap-4">
        <a
          href="/auth/login"
          class="bg-indigo-600 text-white px-6 py-3 rounded-lg hover:bg-indigo-700 transition duration-200"
        >
          <i class="fa-solid fa-sign-in-alt mr-2"></i>Login
        </a>
        <a
          href="/auth/signup"
          class="bg-white text-indigo-600 border border-indigo-600 px-6 py-3 rounded-lg hover:bg-indigo-50 transition duration-200"
        >
          <i class="fa-solid fa-user-plus mr-2"></i>Sign Up
        </a>
      </div>
    </div>
    <div class="grid md:grid-cols-3 gap-8 mt-8">
      <div
        class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 text-center"
      >
        <i class="fa-solid fa-upload text-3xl text-indigo-500 mb-4"></i>
        <h3 class="text-lg font-semibold text-gray-800 mb-2">Easy Upload</h3>
        <p class="text-gray-600">Upload files easily with just a few clicks</p>
      </div>
      <div
        class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 text-center"
      >
        <i class="fa-solid fa-folder text-3xl text-indigo-500 mb-4"></i>
        <h3 class="text-lg font-semibold text-gray-800 mb-2">Organize</h3>
        <p class="text-gray-600">
          Create folders and keep your files organized
        </p>
      </div>
      <div
        class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 text-center"
      >
        <i class="fa-solid fa-shield-alt text-3xl text-indigo-500 mb-4"></i>
        <h3 class="text-lg font-semibold text-gray-800 mb-2">Secure</h3>
        <p class="text-gray-600">Your files are stored securely in the cloud</p>
      </div>
    </div>
  </div>
  <% } %>
</div>
